# ScanDesk — Ortam Değişkenleri
# Kopyala: cp .env.example .env
# Ardından .env içindeki değerleri düzenle.

# API erişim anahtarı — ScanDesk Ayarlar > API Key ile aynı olmalı
API_KEY=buraya_guclu_bir_api_key_yaz

# PostgreSQL şifresi — docker-compose otomatik kullanır
DB_PASSWORD=güçlü_bir_şifre_yaz

# Sunucunun dinleyeceği port (varsayılan: 3000)
PORT=3000

# ── Build-time Uygulama Konfigürasyonu ────────────────────────────────────────
# VITE_ prefix'li değişkenler React/Capacitor build'ine gömülür.
# Bu sayede Android APK kurulunca sadece giriş yapmak yeterlidir;
# kullanıcının Ayarlar'dan sunucu URL veya API key girmesi gerekmez.
#
# VITE_SERVER_URL: Uygulamanın bağlanacağı sunucu adresi (domain veya IP:port)
#   - Hem tarayıcı hem Android APK için aynı URL kullanılır.
#   - Boş bırakılırsa uygulama başlangıçta entegrasyonu devre dışı açar
#     (kullanıcı Ayarlar'dan manuel yapılandırabilir).
VITE_SERVER_URL=https://scandesk.simsekhome.site

# VITE_API_KEY: API_KEY ile aynı değer olmalı
VITE_API_KEY=buraya_guclu_bir_api_key_yaz
